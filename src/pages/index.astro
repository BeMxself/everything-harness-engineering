---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { CardGrid, LinkButton, LinkCard } from "@astrojs/starlight/components";

const frontmatter = {
  title: "Everything Harness Engineering",
  description:
    "一篇面向已听过 harness engineering 一词、但仍希望获得更精确定义、更清晰边界与研究导航的中文综述首页。",
  template: "splash" as const,
  editUrl:
    "https://github.com/BeMxself/everything-harness-engineering/edit/main/src/pages/index.astro",
  hero: {
    title: "Harness Engineering：一个更精确的定义",
    tagline:
      "这不是产品落地页，也不是普通文档目录。它是一篇面向“听过这个词、知道大概意思、但仍缺精确定义与研究导航”的首页综述，目的是先把概念说准，再帮助读者理解这个领域该如何阅读、比较与继续下钻。",
    actions: [
      { text: "先看定义", link: "#definition", icon: "right-arrow" },
      { text: "看详细分类", link: "./distinction/", variant: "secondary" as const },
      {
        text: "进入研究专题",
        link: "./topics/framework-flow-diagrams/site/",
        variant: "minimal" as const,
        icon: "external",
      },
    ],
  },
};

const taxonomy = [
  {
    title: "Native Coding Shells",
    description:
      "宿主 shell 就是主要工作面。执行、工具、权限与 repo 交互都围绕单个 coding agent runtime 展开。",
    href: "./distinction/",
  },
  {
    title: "Harness Overlays",
    description:
      "构建在宿主 shell 之上的第二层系统，显式加入 hooks、teams、memory、HUD、guardrails 与恢复机制。",
    href: "./distinction/",
  },
  {
    title: "Skill / Methodology Systems",
    description:
      "更强调 skills、meta-prompting、spec-driven development 与执行纪律，而不只是某个宿主 shell。",
    href: "./distinction/",
  },
  {
    title: "Workflow / Orchestration Suites",
    description:
      "更强调长时交付闭环、多 agent 协同，以及跨角色或跨模型的结构化任务执行。",
    href: "./distinction/",
  },
];

const timeline = [
  {
    date: "2024-12",
    title: "Building Effective Agents",
    source: "Anthropic",
    summary:
      "把 workflows 与 agents 区分开来，并把简单、可组合模式当成一等工程对象来看待。",
    href: "./timeline/",
  },
  {
    date: "2025-09",
    title: "Writing Effective Tools for Agents",
    source: "Anthropic",
    summary:
      "提醒我们：tool surface 的设计本身就是 harness 的一部分，而不是它外面的次级问题。",
    href: "./timeline/",
  },
  {
    date: "2025-11",
    title: "Effective Harnesses for Long-Running Agents",
    source: "Anthropic",
    summary:
      "通过 handoff、progress tracking 与 task continuation，把 harness 设计具体落到长时 coding agent 场景里。",
    href: "./timeline/",
  },
  {
    date: "2026-02",
    title: "Harness Engineering",
    source: "OpenAI + Martin Fowler",
    summary:
      "这个词开始作为工程抽象真正变得可读：它讨论的是如何 steer、constrain 并 operationalize agent systems。",
    href: "./timeline/",
  },
  {
    date: "2026-03",
    title: "The Anatomy of an Agent Harness",
    source: "LangChain Blog",
    summary:
      "从部件层面把 “model + harness” 这个表达拆开，让它可检查、可讨论、可比较。",
    href: "./timeline/",
  },
];

const landscapeRows = [
  ["Codex", "Native Coding Shell", "Terminal-native coding agent runtime"],
  ["OpenCode", "Native Coding Shell", "Open source coding shell / runtime"],
  ["oh-my-codex", "Harness Overlay", "Codex control layer with hooks, HUDs, and teams"],
  ["Trellis", "Harness Overlay", "Cross-host harness layer"],
  ["superpowers", "Skill / Methodology", "Agentic skills framework and development method"],
  ["gstack", "Workflow / Orchestration", "Role-oriented delivery workflow suite"],
];

const communityThreads = [
  "一条持续更新的 LINUX DO 长帖，记录了真实实践成本、handoff 模式与失败形态。",
  "它把 OMO、Claude Code、Codex 增强层与 AI-native workflow 讨论串联进了同一上下文。",
  "它的价值主要在于暴露现实：长任务里真正主导成本的，往往是控制面、上下文清洁与可恢复性。",
];

const topics = [
  {
    title: "framework-flow-diagrams",
    description:
      "一个可运行的研究应用，用来比较不同系统里的 automation loop、harness 层、控制点、宿主依赖与角色交接方式。",
    href: "./topics/framework-flow-diagrams/site/",
  },
];
---

<StarlightPage frontmatter={frontmatter} hasSidebar={false}>
  <div class="overview-home">
    <div class="overview-nav not-content">
      <a href="#definition">定义</a>
      <a href="#boundary">边界</a>
      <a href="#taxonomy">分类</a>
      <a href="#timeline">时间线</a>
      <a href="#landscape">生态</a>
      <a href="#topics">专题</a>
    </div>

    <section id="definition" class="overview-section overview-section--definition">
      <div class="overview-grid">
        <div class="overview-prose">
          <p class="section-label">Definition First</p>
          <h2>Harness engineering 研究的，是 agent 外层系统本身。</h2>
          <p class="lead">
            在这个仓库里，<strong>harness engineering</strong> 指的是那层被工程化出来的外壳系统：
            它负责约束、编排、验证、恢复，并让 agent 足够可读、可控，能够真正跑进软件工程工作流中。
            模型当然重要，但真正把模型能力变成 durable engineering surface 的，是 harness。
          </p>
          <p>
            这意味着首页要研究的中心对象，既不是模型本身，也不是 prompt 本身，而是模型外面的整套系统：
            task intake、tool surface、execution boundaries、memory、approval、review discipline
            与 handoff structure。
          </p>
        </div>

        <aside id="boundary" class="boundary-panel not-content">
          <p class="section-label">What It Is Not</p>
          <ul>
            <li>不只是单次会话里的 prompt engineering。</li>
            <li>不只是某个 coding agent 产品或 IDE 插件。</li>
            <li>不只是一个提供抽象 orchestration primitives 的 agent framework。</li>
            <li>不只是画出了流程，但没有 durable execution shell 的 workflow 图。</li>
          </ul>
          <LinkButton href="./definition/" variant="secondary" icon="right-arrow">
            查看完整定义
          </LinkButton>
        </aside>
      </div>
    </section>

    <section class="overview-section">
      <div class="overview-prose">
        <p class="section-label">Why Study It Separately</p>
        <h2>当模型能力足够强，瓶颈就开始向外移动。</h2>
        <p>
          Harness engineering 值得被单独当成一个研究类别，是因为很多实际失败已经不再只是模型不够强。
          它们更多来自边界太弱、验证不足、续跑不可靠、任务状态不可读，以及 human steering 与
          agent execution 之间责任分界不清。
        </p>
      </div>

      <div class="reason-grid not-content">
        <div class="reason-card">
          <h3>Constraint</h3>
          <p>
            真实工作需要的是能跨会话延续的 permissions、guardrails、checks 与 architecture boundaries。
          </p>
        </div>
        <div class="reason-card">
          <h3>Recovery</h3>
          <p>
            长任务成败更多取决于 clean handoff、resumability 与 progress legibility，而不只是局部代码生成质量。
          </p>
        </div>
        <div class="reason-card">
          <h3>Coordination</h3>
          <p>
            控制面经常比代码面更重。规划、委派、评审与综合，本身都会变成系统的一部分。
          </p>
        </div>
      </div>
    </section>

    <section id="taxonomy" class="overview-section">
      <div class="overview-section-head">
        <div class="overview-prose">
          <p class="section-label">Research Taxonomy</p>
          <h2>不同系统，解决的是不同层面的外壳问题。</h2>
          <p>
            一旦你不再把所有 agent tooling 都混成一类，这个领域就会清楚很多。下面这套分类是研究性 taxonomy，
            不是某家厂商的 canonical taxonomy。
          </p>
        </div>
        <LinkButton href="./distinction/" variant="minimal" icon="right-arrow">
          查看完整分类
        </LinkButton>
      </div>

      <CardGrid stagger={true}>
        {taxonomy.map((item) => (
          <LinkCard title={item.title} description={item.description} href={item.href} />
        ))}
      </CardGrid>
    </section>

    <section id="timeline" class="overview-section">
      <div class="overview-section-head">
        <div class="overview-prose">
          <p class="section-label">Primary Sources</p>
          <h2>只有看到它是怎么形成的，这个词才会真正变清楚。</h2>
          <p>
            这不是一组随便拼起来的文章。时间线展示的是讨论如何从一般 agent design，转向 tool
            surface，再到 long-running harness，最后收敛成更清晰的工程抽象。
          </p>
        </div>
        <LinkButton href="./timeline/" variant="minimal" icon="right-arrow">
          查看完整时间线
        </LinkButton>
      </div>

      <div class="timeline-list not-content">
        {timeline.map((item) => (
          <article class="timeline-item">
            <div class="timeline-date">{item.date}</div>
            <div class="timeline-copy">
              <h3>{item.title}</h3>
              <p class="timeline-source">{item.source}</p>
              <p>{item.summary}</p>
              <a href={item.href}>看详细时间线</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="overview-section">
      <div class="overview-grid overview-grid--community">
        <div class="overview-prose">
          <p class="section-label">Community Practice</p>
          <h2>社区材料的重要性，在于它暴露了官方文章会压缩掉的真实成本。</h2>
          <p>
            这个仓库里收录的社区讨论之所以重要，不是因为它给出了 canonical definition，而是因为它展示了
            long-running practice 的真实体感：时间花在哪里、什么地方会坏掉、哪些东西必须被显式写出来，任务才能继续跑下去。
          </p>
          <ul>
            {communityThreads.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <LinkButton href="./community/" variant="secondary" icon="right-arrow">
            查看社区讨论与实践观察
          </LinkButton>
        </div>

        <div class="community-insights not-content">
          <h3>Practice Signals</h3>
          <ul>
            <li>长任务里控制面工作往往比代码面更重。</li>
            <li>Clean handoff 和 context hygiene 是核心能力，不是后期打磨。</li>
            <li>模型可用性与成本现实会持续反塑 harness design。</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="landscape" class="overview-section">
      <div class="overview-section-head">
        <div class="overview-prose">
          <p class="section-label">Current Landscape</p>
          <h2>生态不是胜负榜，而是一组不同的 engineering surfaces。</h2>
          <p>
            下面这张表只是一道切面。它的目的不是替你排名，而是帮助读者学会怎么读生态：按 host layer、
            harness layer、methodology layer 与 orchestration layer 去看。
          </p>
        </div>
        <LinkButton href="./landscape/" variant="minimal" icon="right-arrow">
          查看完整生态
        </LinkButton>
      </div>

      <div class="table-wrap not-content">
        <table class="landscape-table">
          <thead>
            <tr>
              <th>System</th>
              <th>Research Category</th>
              <th>Primary Orientation</th>
            </tr>
          </thead>
          <tbody>
            {landscapeRows.map(([system, category, summary]) => (
              <tr>
                <td>{system}</td>
                <td>{category}</td>
                <td>{summary}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="topics" class="overview-section">
        <div class="overview-section-head">
        <div class="overview-prose">
          <p class="section-label">Research Topics</p>
          <h2>这个仓库不会停在综述层，它会继续下沉到可运行专题。</h2>
          <p>
            根站保持轻量、比较型与导航型。更深的工作继续放到
            <code> topics/</code> 下，让每个 topic 都能逐渐长成更独立的研究 artifact。
          </p>
        </div>
      </div>

      <CardGrid>
        {topics.map((topic) => (
          <LinkCard title={topic.title} description={topic.description} href={topic.href} />
        ))}
      </CardGrid>
    </section>

    <section class="overview-section overview-section--next">
      <div class="overview-prose">
        <p class="section-label">Next Steps</p>
        <h2>如果这个词现在已经清楚一些了，下一步就应该按问题去读，而不是按 hype 去追。</h2>
      </div>

      <CardGrid>
        <LinkCard
          title="我想先看精确定义"
          description="从仓库里的工程定义与明确边界开始。"
          href="./definition/"
        />
        <LinkCard
          title="我想先理解怎么选路线"
          description="在比较产品或 workflow 之前，先看研究性分类。"
          href="./distinction/"
        />
        <LinkCard
          title="我想看这个领域是怎么形成的"
          description="用时间线和生态页理解它如何形成，又正在向哪里漂移。"
          href="./timeline/"
        />
        <LinkCard
          title="我想直接看可运行材料"
          description="直接进入 topic app，从一个具体研究 artifact 开始。"
          href="./topics/framework-flow-diagrams/site/"
        />
      </CardGrid>
    </section>
  </div>
</StarlightPage>

<style is:global>
  body:has(.overview-home) .main-pane {
    --sl-content-width: min(78rem, calc(100vw - 2.5rem));
  }

  body:has(.overview-home) .content-panel {
    padding-block: 2rem;
  }

  .overview-home {
    display: grid;
    gap: 2rem;
  }

  .overview-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-bottom: 0.5rem;
  }

  .overview-nav a {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    text-decoration: none;
    color: var(--sl-color-text);
    background: color-mix(in srgb, var(--sl-color-black) 88%, transparent);
  }

  .overview-nav a:hover {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-white);
  }

  .overview-section {
    display: grid;
    gap: 1.25rem;
  }

  .overview-section--definition {
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.5rem;
  }

  .overview-section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .overview-grid {
    display: grid;
    gap: 1.25rem;
  }

  .overview-grid--community {
    align-items: start;
  }

  .overview-prose {
    max-width: 46rem;
  }

  .section-label {
    margin: 0;
    color: var(--sl-color-text-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .lead {
    font-size: clamp(1.08rem, 0.98rem + 0.4vw, 1.28rem);
    line-height: 1.7;
    color: var(--sl-color-white);
  }

  .boundary-panel,
  .community-insights,
  .reason-card,
  .timeline-item {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-black) 86%, transparent);
    border-radius: 1rem;
    padding: 1.15rem 1.2rem;
  }

  .boundary-panel ul,
  .community-insights ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  .reason-grid {
    display: grid;
    gap: 1rem;
  }

  .reason-card h3,
  .community-insights h3,
  .timeline-copy h3 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .reason-card p,
  .timeline-copy p,
  .community-insights li,
  .boundary-panel li {
    color: var(--sl-color-gray-2);
  }

  .timeline-list {
    display: grid;
    gap: 1rem;
  }

  .timeline-item {
    display: grid;
    gap: 0.85rem;
  }

  .timeline-date {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-text-accent);
  }

  .timeline-source {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-size: 0.92rem;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-black) 90%, transparent);
  }

  .landscape-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 52rem;
  }

  .landscape-table th,
  .landscape-table td {
    padding: 0.95rem 1rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .landscape-table th {
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-gray-6) 70%, transparent);
  }

  .landscape-table tr:last-child td {
    border-bottom: 0;
  }

  .overview-section--next {
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.5rem;
  }

  @media (min-width: 50rem) {
    .overview-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.85fr);
    }

    .reason-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .timeline-item {
      grid-template-columns: 6rem minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
