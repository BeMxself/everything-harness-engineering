---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import HomeCommunitySection from "../components/home/HomeCommunitySection.astro";
import HomeDefinitionSection from "../components/home/HomeDefinitionSection.astro";
import HomeEcosystemComparisonSection from "../components/home/HomeEcosystemComparisonSection.astro";
import HomeFundamentalsSection from "../components/home/HomeFundamentalsSection.astro";
import HomeNav from "../components/home/HomeNav.astro";
import HomeNextSection from "../components/home/HomeNextSection.astro";
import HomeObservationsSection from "../components/home/HomeObservationsSection.astro";
import HomeTimelineSection from "../components/home/HomeTimelineSection.astro";
import HomeTopicsSection from "../components/home/HomeTopicsSection.astro";
import HomeWhySection from "../components/home/HomeWhySection.astro";
import {
  communityInsights,
  communityIntro,
  communityThreads,
  fundamentals,
  hero,
  landscapePreviewRows,
  navItems,
  nextLinks,
  taxonomy,
  timeline,
  topics,
} from "../data/homepage";

const frontmatter = {
  title: "Everything Harness Engineering",
  description:
    "一篇面向已听过 harness engineering 一词、但仍希望获得更精确定义、更清晰边界与研究导航的中文综述首页。",
  template: "splash" as const,
  editUrl:
    "https://github.com/BeMxself/everything-harness-engineering/edit/main/src/pages/index.astro",
  hero,
};
---

<StarlightPage frontmatter={frontmatter} hasSidebar={false}>
  <div class="overview-home">
    <HomeNav items={navItems} />
    <HomeDefinitionSection />
    <HomeNextSection items={nextLinks} />
    <HomeWhySection />
    <HomeTimelineSection items={timeline} />
    <HomeFundamentalsSection items={fundamentals} />
    <HomeEcosystemComparisonSection taxonomy={taxonomy} rows={landscapePreviewRows} />
    <HomeTopicsSection items={topics} />
    <HomeCommunitySection
      intro={communityIntro}
      threads={communityThreads}
    />
    <HomeObservationsSection insights={communityInsights} />
  </div>
</StarlightPage>

<script>
  const navLinks = Array.from(
    document.querySelectorAll(".overview-nav a"),
  );
  const sections = Array.from(
    document.querySelectorAll(".overview-section[id]"),
  );

  const setActiveLink = (id: string) => {
    for (const link of navLinks) {
      const isActive = link.getAttribute("href") === `#${id}`;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "true");
      } else {
        link.removeAttribute("aria-current");
      }
    }
  };

  if (sections.length > 0) {
    const getActiveSectionId = () => {
      const anchor = window.innerHeight * 0.35;
      let fallback: HTMLElement | undefined;

      for (const section of sections) {
        const element = section as HTMLElement;
        const rect = element.getBoundingClientRect();

        if (rect.top <= anchor) {
          fallback = element;
        }

        if (rect.top <= anchor && rect.bottom >= anchor) {
          return element.id;
        }
      }

      return fallback?.id ?? (sections[0] as HTMLElement | undefined)?.id;
    };

    let frame = 0;
    const syncActiveLink = () => {
      frame = 0;
      const id = getActiveSectionId();
      if (id) setActiveLink(id);
    };

    const scheduleSync = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(syncActiveLink);
    };

    window.addEventListener("scroll", scheduleSync, { passive: true });
    window.addEventListener("resize", scheduleSync);

    const initial = sections.find((section) => section.id === location.hash.slice(1))
      ?? sections[0];
    if (initial?.id) {
      setActiveLink(initial.id);
    }
    scheduleSync();
  }
</script>

<style is:global>
  body:has(.overview-home) .main-pane {
    --sl-content-width: min(78rem, calc(100vw - 2.5rem));
  }

  body:has(.overview-home) .content-panel {
    padding-block: 2rem;
  }

  .overview-home {
    display: grid;
    gap: 2rem;
  }

  .overview-nav-shell {
    position: static;
    margin-top: 0;
  }

  .overview-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(10rem, 100%), 1fr));
    gap: 0.65rem;
    padding: 0.8rem 0.1rem 0.7rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--sl-color-bg) 92%, transparent) 0%,
        color-mix(in srgb, var(--sl-color-bg) 84%, transparent) 100%
      );
    backdrop-filter: blur(18px);
  }

  .overview-nav a {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.6rem 0.95rem;
    text-decoration: none;
    color: var(--sl-color-text);
    background: color-mix(in srgb, var(--sl-color-black) 88%, transparent);
    text-align: center;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .overview-nav a:hover,
  .overview-nav a.is-active {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-text-accent) 18%, var(--sl-color-black));
  }

  .overview-nav a.is-active {
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--sl-color-text-accent) 28%, transparent);
  }

  .overview-section {
    display: grid;
    gap: 1.35rem;
    position: relative;
    padding: clamp(2.25rem, 3vw, 3.5rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.5rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--sl-color-black) 94%, transparent) 0%,
        color-mix(in srgb, var(--sl-color-black) 88%, transparent) 100%
      );
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--sl-color-gray-5) 42%, transparent),
      0 18px 45px color-mix(in srgb, var(--sl-color-black) 22%, transparent);
    scroll-margin-top: calc(var(--sl-nav-height) + 5rem);
  }

  .overview-section--definition {
    padding-top: clamp(2.5rem, 3vw, 3.8rem);
  }

  .overview-section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .overview-grid {
    display: grid;
    gap: 1.25rem;
  }

  .overview-grid--community {
    align-items: start;
  }

  .overview-prose {
    max-width: 46rem;
  }

  .overview-prose--wide {
    max-width: none;
  }

  .section-label {
    margin: 0;
    color: var(--sl-color-text-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .lead {
    font-size: clamp(1.08rem, 0.98rem + 0.4vw, 1.28rem);
    line-height: 1.7;
    color: var(--sl-color-white);
  }

  .boundary-panel,
  .community-insights,
  .reason-card,
  .timeline-item,
  .thread-card,
  .taxonomy-card,
  .insight-item {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-black) 86%, transparent);
    border-radius: 1rem;
    padding: 1.15rem 1.2rem;
  }

  .boundary-panel ul,
  .community-insights ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  .reason-grid {
    display: grid;
    gap: 1rem;
  }

  .evolution-flow {
    display: grid;
    gap: 0.75rem;
    align-items: stretch;
  }

  .evolution-card {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-black) 86%, transparent);
    border-radius: 1rem;
    padding: 1.1rem 1.15rem;
  }

  .evolution-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }

  .evolution-card p {
    margin: 0;
    color: var(--sl-color-gray-2);
  }

  .evolution-card p + p {
    margin-top: 0.55rem;
  }

  .evolution-stage {
    color: var(--sl-color-text-accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .evolution-bottleneck {
    color: var(--sl-color-white);
  }

  .evolution-arrow {
    display: grid;
    place-items: center;
    color: var(--sl-color-text-accent);
    font-size: 1.5rem;
    line-height: 1;
    min-height: 2rem;
  }

  .evolution-summary {
    max-width: 46rem;
    color: var(--sl-color-gray-2);
  }

  .thread-list,
  .fundamentals-grid,
  .observations-grid,
  .taxonomy-grid {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .ecosystem-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .section-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .ecosystem-kinds {
    display: grid;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }

  .ecosystem-kinds > p {
    margin: 0;
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .ecosystem-kind-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .ecosystem-kind-list li {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-black) 86%, transparent);
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    display: grid;
    gap: 0.35rem;
  }

  .ecosystem-kind-list li strong {
    color: var(--sl-color-white);
  }

  .ecosystem-kind-list li span {
    color: var(--sl-color-gray-2);
  }

  .ecosystem-preview-note {
    margin: 0;
    color: var(--sl-color-gray-3);
  }

  .fundamental-card {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-black) 86%, transparent);
    border-radius: 1rem;
    padding: 1.15rem 1.2rem;
  }

  .fundamental-card h3 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .fundamental-card p {
    margin: 0;
    color: var(--sl-color-gray-2);
  }

  .thread-card h3,
  .taxonomy-card h3,
  .insight-item h4 {
    margin: 0 0 0.45rem;
  }

  .thread-meta {
    margin: 0 0 0.55rem;
    color: var(--sl-color-text-accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .taxonomy-note {
    color: var(--sl-color-gray-3);
    font-size: 0.96rem;
  }

  .insight-item + .insight-item {
    margin-top: 1rem;
  }

  .reason-card h3,
  .community-insights h3,
  .timeline-copy h3 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .reason-card p,
  .timeline-copy p,
  .community-insights li,
  .boundary-panel li {
    color: var(--sl-color-gray-2);
  }

  .timeline-list {
    display: grid;
    gap: 1rem;
  }

  .timeline-item {
    display: grid;
    gap: 0.85rem;
  }

  .timeline-date {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-text-accent);
  }

  .timeline-source {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-size: 0.92rem;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-black) 90%, transparent);
  }

  .landscape-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 52rem;
  }

  .landscape-table th,
  .landscape-table td {
    padding: 0.95rem 1rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .landscape-table th {
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-gray-6) 70%, transparent);
  }

  .landscape-table tr:last-child td {
    border-bottom: 0;
  }

  .suite-cell {
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  .suite-cell a {
    font-weight: 600;
  }

  .stars-badge {
    display: block;
    max-width: 100%;
    height: 1.25rem;
  }

  .overview-section--next {
    padding-bottom: clamp(2.5rem, 3vw, 4rem);
  }

  @media (min-width: 50rem) {
    .overview-nav-shell {
      position: sticky;
      top: calc(var(--sl-nav-height) + 0.75rem);
      z-index: calc(var(--sl-z-index-navbar) - 1);
      margin-top: -0.25rem;
    }

    .overview-nav {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .overview-nav a {
      white-space: nowrap;
    }

    .overview-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.85fr);
    }

    .reason-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .evolution-flow {
      grid-template-columns:
        minmax(0, 1fr) auto
        minmax(0, 1fr) auto
        minmax(0, 1fr) auto
        minmax(0, 1fr) auto
        minmax(0, 1fr);
    }

    .thread-list,
    .fundamentals-grid,
    .observations-grid,
    .ecosystem-kind-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .timeline-item {
      grid-template-columns: 6rem minmax(0, 1fr);
      align-items: start;
    }
  }

  @media (min-width: 72rem) {
    .overview-home {
      gap: 2.5rem;
    }

    .overview-nav-shell {
      top: calc(var(--sl-nav-height) + 1rem);
    }

    .overview-section {
      min-height: calc(100svh - var(--sl-nav-height) - 6.5rem);
      align-content: start;
    }
  }
</style>
