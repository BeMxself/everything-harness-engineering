---
import { landscapeColumns, landscapeIntro, landscapeNote, landscapeRows } from "../data";
---

<section id="landscape" class="section">
  <h2>Current Landscape</h2>
  <p class="section-copy">{landscapeIntro}</p>
  <div class="comparison-table-wrap">
    <table class="comparison-table">
      <thead>
        <tr>
          <th>系统</th>
          <th>官方自述 / 定位信号</th>
          <th>首页归类</th>
          <th>宿主 / 主要范围</th>
        </tr>
      </thead>
      <tbody>
        {landscapeRows.map(([label, url, signal, category, scope]) => (
          <tr>
            <td><a href={url}>{label}</a></td>
            <td>{signal}</td>
            <td>{category}</td>
            <td>{scope}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="landscape-grid">
    {landscapeColumns.map((column) => (
      <article class="landscape-column">
        <h3>{column.title}</h3>
        <ul>
          {column.items.map(([label, url]) => (
            <li><a href={url}>{label}</a></li>
          ))}
        </ul>
        <p class="column-note">{column.note}</p>
      </article>
    ))}
  </div>
  <p class="section-copy">
    <strong>注：</strong>
    {landscapeNote}
  </p>
</section>
