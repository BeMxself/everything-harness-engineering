---
import { heroContent, pageMeta } from "../data";
---

<section class="hero">
  <p class="eyebrow">{heroContent.eyebrow}</p>
  <h1>{heroContent.title}</h1>
  <p class="hero-copy">{heroContent.copy}</p>
  <div class="hero-meta">
    <span>更新于 {pageMeta.updatedAt}</span>
    <a href={pageMeta.githubUrl}>GitHub Repo</a>
  </div>
</section>
