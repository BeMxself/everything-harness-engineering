---
import { CardGrid, LinkCard } from "@astrojs/starlight/components";

interface NextLink {
  title: string;
  description: string;
  href: string;
}

interface Props {
  items: NextLink[];
}

const { items } = Astro.props;
---

<section id="next" class="overview-section overview-section--next">
  <div class="overview-prose">
    <p class="section-label">开始阅读</p>
    <h2>先按问题进入本站，而不是从最长的页面开始硬读。</h2>
    <p>
      这一组入口就是首页最重要的功能：把你送去合适的正文页，而不是把正文再重复一遍。
    </p>
  </div>

  <CardGrid>
    {items.map((item) => (
      <LinkCard title={item.title} description={item.description} href={item.href} />
    ))}
  </CardGrid>
</section>
