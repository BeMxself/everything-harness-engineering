---
import { LinkButton } from "@astrojs/starlight/components";

interface CommunityThread {
  title: string;
  href: string;
  date: string;
  summary: string;
}

interface Props {
  intro: string;
  threads: CommunityThread[];
}

const { intro, threads } = Astro.props;
---

<section id="community" class="overview-section">
  <div class="overview-prose overview-prose--wide">
    <p class="section-label">社区讨论</p>
    <h2>如果想看这个概念在真实使用中怎么被消化，社区材料很重要。</h2>
    <p>{intro}</p>
    <div class="thread-list not-content">
      {threads.map((item) => (
        <article class="thread-card">
          <p class="thread-meta">{item.date}</p>
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
    <LinkButton href="/everything-harness-engineering/community-discussions/" variant="secondary" icon="right-arrow">
      查看社区讨论
    </LinkButton>
  </div>
</section>
