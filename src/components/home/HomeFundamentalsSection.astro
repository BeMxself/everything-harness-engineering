---
import { LinkButton } from "@astrojs/starlight/components";

interface FundamentalItem {
  title: string;
  summary: string;
}

interface Props {
  items: FundamentalItem[];
}

const { items } = Astro.props;
---

<section id="fundamentals" class="overview-section">
  <div class="overview-section-head">
    <div class="overview-prose">
      <p class="section-label">基本构成</p>
      <h2>要理解 Harness Engineering，先要看清宿主和 Agent Harnesses 暴露了哪些底层能力。</h2>
      <p>
        这些能力不都来自同一层。<strong>AI Agents</strong> 先提供主执行面，
        <strong>Agent Harnesses</strong> 再把状态、控制、恢复和流程编成外层系统。下面这些项更适合先看成
        <strong>harness 机制</strong>：它们是被系统调用和组合的能力，不等于对象层分类本身。
      </p>
    </div>
    <div class="section-actions not-content">
      <LinkButton href="/everything-harness-engineering/concept-entry/" variant="minimal" icon="right-arrow">
        去看完整构成说明
      </LinkButton>
    </div>
  </div>

  <div class="fundamentals-grid not-content">
    {items.map((item) => (
      <article class="fundamental-card">
        <h3>{item.title}</h3>
        <p>{item.summary}</p>
      </article>
    ))}
  </div>
</section>
