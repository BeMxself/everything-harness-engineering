---
import { LinkButton } from "@astrojs/starlight/components";

interface TimelineItem {
  date: string;
  title: string;
  source: string;
  summary: string;
  href: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<section id="timeline" class="overview-section">
  <div class="overview-section-head">
    <div class="overview-prose">
      <p class="section-label">关键文章</p>
      <h2>想真正理解 harness engineering，最好回到把它说清楚的那些文章。</h2>
      <p>
        正文页现在是一份注释型导读，不只是时间线。首页这里只保留几个关键转折点，让你先知道该从哪篇进入。
      </p>
    </div>
    <LinkButton href="/everything-harness-engineering/key-articles/" variant="minimal" icon="right-arrow">
      查看关键文章导读
    </LinkButton>
  </div>

  <div class="timeline-list not-content">
    {items.map((item) => (
      <article class="timeline-item">
        <div class="timeline-date">{item.date}</div>
        <div class="timeline-copy">
          <h3><a href={item.href}>{item.title}</a></h3>
          <p class="timeline-source">{item.source}</p>
          <p>{item.summary}</p>
        </div>
      </article>
    ))}
  </div>
</section>
