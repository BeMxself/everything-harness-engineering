---
import { LinkButton } from "@astrojs/starlight/components";

interface CommunityInsight {
  title: string;
  summary: string;
}

interface Props {
  insights: CommunityInsight[];
}

const { insights } = Astro.props;
---

<section id="observations" class="overview-section">
  <div class="overview-prose">
    <p class="section-label">工程观察</p>
    <h2>把这些社区材料放在一起看，会慢慢浮现出一些稳定的实践判断。</h2>
    <p>
      这些判断不是官方定义，但它们能帮助你更快看出：真实使用里哪些问题反复出现，哪些才是系统真正的负重点。
    </p>
    <div class="section-actions not-content">
      <LinkButton href="/everything-harness-engineering/engineering-observations/" variant="minimal" icon="right-arrow">
        去看完整观察页
      </LinkButton>
    </div>
  </div>

  <div class="observations-grid not-content">
    {insights.map((item) => (
      <div class="insight-item">
        <h4>{item.title}</h4>
        <p>{item.summary}</p>
      </div>
    ))}
  </div>
</section>
