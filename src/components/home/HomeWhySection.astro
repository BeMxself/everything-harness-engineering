---
import { LinkButton } from "@astrojs/starlight/components";

const stages = [
  {
    stage: "阶段 1",
    title: "代码补全",
    shift: "目标是把局部生成质量做得更高。",
    bottleneck: "瓶颈：模型能不能写对这一段代码？",
  },
  {
    stage: "阶段 2",
    title: "对话式编程",
    shift: "开始跨文件理解需求、解释代码、提出修改。",
    bottleneck: "瓶颈：上下文理解够不够完整？",
  },
  {
    stage: "阶段 3",
    title: "AI Agents",
    shift: "代理直接读仓库、改文件、跑命令、做验证。",
    bottleneck: "瓶颈：能不能把单次任务真正执行完？",
  },
  {
    stage: "阶段 4",
    title: "Agent Harnesses",
    shift: "控制、恢复、记忆、规则与交接开始变成核心。",
    bottleneck: "瓶颈：长任务能否持续、可控、可恢复地跑？",
  },
  {
    stage: "阶段 5",
    title: "Harness Engineering",
    shift: "控制、交接、评审、规则和长期方法进入主舞台。",
    bottleneck: "瓶颈：怎样把这些能力组织成长期、稳定、可治理的开发方法？",
  },
];
---

<section id="why" class="overview-section">
  <div class="overview-prose">
    <p class="section-label">演进与瓶颈</p>
    <h2>AI 编程范式在演进，瓶颈也在迁移。</h2>
    <p>
      讨论之所以会从补全、对话式编程一路转向 <code>AI Agents</code>、<code>Agent Harnesses</code> 和
      <code>Harness Engineering</code>，本质上是因为瓶颈已经从生成质量迁移到了底层能力、恢复能力和控制结构。
      真正变重的是模型之外的执行宿主、外层 harness 和人类围绕它们组织出的长期方法。
    </p>
  </div>

  <div class="evolution-flow not-content" aria-label="AI 编程范式演进流程图">
    {stages.map((item, index) => (
      <>
        <article class="evolution-card">
          <p class="evolution-stage">{item.stage}</p>
          <h3>{item.title}</h3>
          <p>{item.shift}</p>
          <p class="evolution-bottleneck">{item.bottleneck}</p>
        </article>
        {index < stages.length - 1 && (
          <div class="evolution-arrow" aria-hidden="true">
            <span>→</span>
          </div>
        )}
      </>
    ))}
  </div>

  <p class="evolution-summary">
    真正重要的不是某一层替代了前一层，而是瓶颈在持续外移，系统必须回答的问题也随之改变。
  </p>

  <div class="section-actions not-content">
    <LinkButton href="/everything-harness-engineering/concept-entry/" variant="minimal" icon="right-arrow">
      去看完整概念解释
    </LinkButton>
  </div>
</section>
