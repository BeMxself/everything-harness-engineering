---
import { topics, topicsIntro } from "../data";
---

<section id="topics" class="section">
  <h2>Research Topics</h2>
  <p class="section-copy">{topicsIntro}</p>
  {topics.map((topic) => (
    <div class="topic-card">
      <h3>{topic.title}</h3>
      <p>{topic.summary}</p>
      <div class="topic-links">
        <a href={topic.openUrl}>Open</a>
        <a href={topic.sourceUrl}>Source</a>
      </div>
    </div>
  ))}
</section>
